{
  "name": "memory-lancedb-mcp",
  "version": "0.1.0",
  "description": "MCP Server wrapper for memory-lancedb-pro — zero-modification adapter replacing OpenClaw runtime",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mem": "./bin/mem.mjs"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js serve",
    "test": "node --test test/*.test.mjs",
    "test:cli": "node --test test/cli.test.mjs",
    "test:mcp": "node --test test/mcp.test.mjs",
    "test:unit": "node --test test/unit/*.test.mjs",
    "test:all": "node test/run-all-tests.mjs",
    "test:report": "node test/run-all-tests.mjs && open test-reports/",
    "setup-hooks": "npx lefthook install",
    "prepare": "[ \"$CI\" = true ] || [ -n \"$GITHUB_ACTIONS\" ] || npx lefthook install"
  },
  "keywords": [
    "mcp",
    "memory",
    "lancedb",
    "ai-memory",
    "long-term-memory",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^14.0.0",
    "jiti": "^2.6.1",
    "memory-lancedb-pro": "github:CortexReach/memory-lancedb-pro#v1.1.0-beta.10",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@evilmartians/lefthook": "^2.0.11",
    "@sinclair/typebox": "0.34.48",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*",
    "bin/**/*",
    "README.md"
  ]
}
